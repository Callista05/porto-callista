#!/bin/gitignore
# Node and package managers
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Astro / build
dist/
.astro/
.cache/
.vercel/
.netlify/

# Local env files
.env
.env.*

# Editor directories and system files
.DS_Store
.vscode/
.idea/
*.sublime-workspace

# Logs
*.log

# OS files
Thumbs.db

# Coverage
/coverage/

# Misc
*.tgz
*.gz
