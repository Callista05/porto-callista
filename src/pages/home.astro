---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio — Astro + Tailwind</title>
  </head>
  <body class="min-h-screen p-8">
    <header class="max-w-6xl mx-auto">
      <h1 class="text-4xl font-bold">Portfolio</h1>
      <p class="mt-2 text-gray-600">A minimal Astro + Tailwind starter for image-forward portfolios.</p>
    </header>

    <main class="max-w-6xl mx-auto mt-8">
      <section>
        <h2 class="text-2xl font-semibold mb-4">Gallery</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          <div class="bg-gray-100 aspect-[4/3] flex items-center justify-center text-gray-400">Image 1</div>
          <div class="bg-gray-100 aspect-[4/3] flex items-center justify-center text-gray-400">Image 2</div>
          <div class="bg-gray-100 aspect-[4/3] flex items-center justify-center text-gray-400">Image 3</div>
          <div class="bg-gray-100 aspect-[4/3] flex items-center justify-center text-gray-400">Image 4</div>
        </div>
      </section>
    </main>

    <footer class="max-w-6xl mx-auto mt-12 text-sm text-gray-500">Built with Astro + Tailwind</footer>
  </body>
</html>
