---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About — Callista V Effendi</title>
  <link href="https://fonts.googleapis.com/css2?family=Nova+Flat&family=Barlow+Condensed:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html, body { height:100%; overflow:hidden; }
    body { background:#050208; font-family:'Nova Flat', cursive; color:#eeebeb; }

    .about-view {
      position:fixed; inset:0;
      transition:opacity .6s ease;
    }
    .about-view.hidden { opacity:0; pointer-events:none; }

    .about-bg {
      position:absolute; inset:0;
      width:100%; height:100%; object-fit:cover;
      pointer-events:none;
    }

    /* ─── Title screen ─── */
    #about-title { cursor:pointer; }
    .about-logo {
      position:absolute; top:50%; left:50%;
      transform:translate(-50%,-50%);
      width:55vw; height:auto;
      animation:logoPulse 3s ease-in-out infinite alternate;
    }
    @keyframes logoPulse {
      from { opacity:.85; transform:translate(-50%,-50%) scale(.99); }
      to   { opacity:1;   transform:translate(-50%,-50%) scale(1.01); }
    }
    .about-hint {
      position:absolute; bottom:2.5rem; left:50%;
      transform:translateX(-50%);
      font-family:'Barlow Condensed',sans-serif;
      font-size:.72rem; letter-spacing:.35em; text-transform:uppercase;
      opacity:.45;
      animation:hintFade 2s ease-in-out infinite alternate;
    }
    @keyframes hintFade { from { opacity:.2; } to { opacity:.6; } }

    /* ─── Slides ─── */
    .about-back {
      position:absolute; top:1.4rem; right:2.5rem;
      background:none; border:none; cursor:pointer;
      opacity:.8; transition:opacity .2s; z-index:6;
    }
    .about-back img { height:.85rem; width:auto; display:block; }
    .about-back:hover { opacity:1; }

    .slide {
      position:absolute; inset:0;
      opacity:0; pointer-events:none;
      transition:opacity .5s ease;
    }
    .slide.active { opacity:1; pointer-events:auto; }
    .slide img { position:absolute; height:auto; }

    /* Slide 1 — intro (heading + bio), positioned on the right of the photo */
    .s-heading { top:20%; left:58%; transform:translate(-50%,-50%); width:56%; }
    .s-bio     { top:70%; left:45%; transform:translate(-50%,-50%); width:30%; }
    /* Slide 2 — skills (full baked SVG) */
    .s-skill   { top:50%; left:53%; transform:translate(-50%,-50%); width:46%; }
    /* Slide 3 — achievements (full baked SVG) */
    .s-achieve { top:50%; left:60%; transform:translate(-50%,-50%); width:60%; }

    /* Nav arrows */
    .about-arrow {
      position:absolute; bottom:2rem;
      background:none; border:none; cursor:pointer;
      opacity:.7; transition:opacity .2s; z-index:6;
      padding:.6rem;
    }
    .about-arrow img { width:1.5rem; height:auto; display:block; }
    .about-arrow:hover { opacity:1; }
    .about-arrow.left  { left:33.5rem; }
    .about-arrow.right { right:2.5rem; }
    .about-arrow.hidden-arrow { display:none; }
  </style>
</head>
<body>

<!-- Title screen -->
<div id="about-title" class="about-view">
  <img class="about-bg" src="/assets/about/Backgroudn 1.svg" alt="" />
  <img class="about-logo" src="/assets/about/pages/logo.svg" alt="LION" />
  <span class="about-hint">Click to enter</span>
</div>

<!-- Slides -->
<div id="about-slides" class="about-view hidden">
  <img class="about-bg" src="/assets/about/Background 2.svg" alt="" />
  <button class="about-back" id="about-back-btn">
    <img src="/assets/uiux/Back.svg" alt="Back" />
  </button>

  <div class="slide" data-slide="0">
    <img class="s-heading" src="/assets/about/pages/p1-heading.svg" alt="Hello, I am Callista V. E." />
    <img class="s-bio"     src="/assets/about/pages/p1-bio.svg" alt="" />
  </div>
  <div class="slide" data-slide="1">
    <img class="s-skill" src="/assets/about/pages/p2-skill.svg" alt="My skills" />
  </div>
  <div class="slide" data-slide="2">
    <img class="s-achieve" src="/assets/about/pages/p3-achievement.svg" alt="My achievements" />
  </div>

  <button class="about-arrow left"  id="about-prev"><img src="/assets/uiux/Arrow Kiri.svg" alt="Previous" /></button>
  <button class="about-arrow right" id="about-next"><img src="/assets/uiux/Arrow kanan.svg" alt="Next" /></button>
</div>

<script>
(function () {
  const titleView = document.getElementById('about-title');
  const slidesView = document.getElementById('about-slides');
  const slides = Array.from(document.querySelectorAll('.slide'));
  const prevBtn = document.getElementById('about-prev');
  const nextBtn = document.getElementById('about-next');
  let idx = 0;
  let entered = false;

  function enter() {
    if (entered) return;
    entered = true;
    titleView.classList.add('hidden');
    slidesView.classList.remove('hidden');
    render();
  }

  function render() {
    slides.forEach((s, i) => s.classList.toggle('active', i === idx));
    prevBtn.classList.toggle('hidden-arrow', idx === 0);
    nextBtn.classList.toggle('hidden-arrow', idx === slides.length - 1);
  }

  function go(d) {
    const n = idx + d;
    if (n < 0 || n > slides.length - 1) return;
    idx = n; render();
  }

  titleView.addEventListener('click', enter);
  prevBtn.addEventListener('click', () => go(-1));
  nextBtn.addEventListener('click', () => go(1));
  document.getElementById('about-back-btn').addEventListener('click', () => window.history.back());

  document.addEventListener('keydown', (e) => {
    if (!entered) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); enter(); }
      return;
    }
    if (e.key === 'ArrowRight') go(1);
    else if (e.key === 'ArrowLeft') go(-1);
    else if (e.key === 'Escape') window.history.back();
  });
})();
</script>
</body>
</html>
