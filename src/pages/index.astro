---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio Landing Page</title>
    <link href="https://fonts.googleapis.com/css2?family=Nova+Flat&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen bg-black overflow-hidden">
    <video id="bgVideo" class="fixed inset-0 w-full h-full object-cover" autoplay muted loop playsinline>
      <source src="/assets/landing/landing.webm" type="video/webm" />
      Your browser does not support the video tag.
    </video>

    <div class="fixed inset-0 bg-black/30 pointer-events-none"></div>

    <div id="clickBar" class="fixed left-0 right-0 bottom-0 h-24 bg-black text-white flex items-center justify-center cursor-pointer" style="font-family: 'Nova Flat', cursive;">
      <div class="text-center">
        <div class="text-5xl tracking-widest">CLICK ME</div>
      </div>
    </div>

    <script>
      document.getElementById('clickBar').addEventListener('click', function(){
        window.location.href = '/home';
      });
      document.addEventListener('keydown', function(e){
        if(e.key === 'Enter') window.location.href = '/home';
      });
    </script>
  </body>
</html>
