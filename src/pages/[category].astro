<script define:vars={{ projectsJSON }}>
(function () {
  const projects = JSON.parse(projectsJSON);

  /* ──────────────────────────────
     PICKER
  ────────────────────────────── */
  const pickerView   = document.getElementById('picker-view');
  const showcaseView = document.getElementById('showcase-view');
  const track        = document.getElementById('carousel-track');
  const tagEl        = document.getElementById('picker-tag');

  let current = 0;
  /* ─── Spinner geometry (tune these two) ─────────────────────────
     Items sit on a wheel whose hub is HUB_X px to the LEFT (the swirl's
     center). Each step from the active item rotates by STEP_DEG, so row
     spacing, the leftward arc, and the tilt all derive from one rotation
     — and the whole wheel appears to spin as you select. */
  const STEP_DEG = 18;   // degrees of rotation per item
  const HUB_X    = 900;  // px to the wheel hub (to the LEFT)

  /* Items are server-rendered in the template (so they pick up scoped
     styles); here we just wire clicks and position them. */
  function buildTrack() {
    if (!track) return;
    track.querySelectorAll('.c-item').forEach((el, i) => {
      el.addEventListener('click', () => {
        if (i === current) openShowcase(i);
        else { current = i; updateCarousel(); }
      });
    });
    updateCarousel();
  }

  function updateCarousel() {
    if (!track) return;
    const items = track.querySelectorAll('.c-item');

    items.forEach((el, i) => {
      const offset = i - current;
      const absOff = Math.abs(offset);

      el.setAttribute('data-active', offset === 0 ? 'true' : 'false');
      el.setAttribute('data-dist', String(absOff));

      /* Rotate about the hub on the LEFT: items above swing up, below swing
         down, all arcing leftward toward the swirl. The active item is
         rotate(0) pinned to the track origin, so it never drifts. */
      const angle = offset * STEP_DEG;
      el.style.transformOrigin = `${-HUB_X}px 0`;
      el.style.transform = `rotate(${angle}deg)`;
      el.style.pointerEvents = absOff <= 1 ? 'auto' : 'none';
    });

    if (tagEl && projects[current]) tagEl.textContent = projects[current].tag;
  }

  /* One step per gesture: the CSS transition (.6s) drives the animation, so
     we lock input until it settles to stop trackpads firing 10 steps at once. */
  let stepLock = false;
  function step(dir) {
    if (stepLock) return;
    const next = current + dir;
    if (next < 0 || next > projects.length - 1) return;
    current = next;
    updateCarousel();
    stepLock = true;
    setTimeout(() => { stepLock = false; }, 480);
  }

  /* Keyboard navigation */
  document.addEventListener('keydown', (e) => {
    if (!pickerView || pickerView.classList.contains('hidden')) return;
    if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
      e.preventDefault();
      step(1);
    } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
      e.preventDefault();
      step(-1);
    } else if (e.key === 'Enter') {
      openShowcase(current);
    } else if (e.key === 'Escape') {
      goHome();
    }
  });

  /* Mouse-wheel navigation */
  document.addEventListener('wheel', (e) => {
    if (!pickerView || pickerView.classList.contains('hidden')) return;
    e.preventDefault();
    if (Math.abs(e.deltaY) < 4) return;
    step(e.deltaY > 0 ? 1 : -1);
  }, { passive: false });

  /* Back buttons */
  const pickerBackBtn = document.getElementById('picker-back-btn');
  const emptyBackBtn  = document.getElementById('empty-back-btn');
  if (pickerBackBtn) pickerBackBtn.addEventListener('click', goHome);
  if (emptyBackBtn)  emptyBackBtn.addEventListener('click', goHome);

  function goHome() { window.history.back(); }

  /* ──────────────────────────────
     SHOWCASE
  ────────────────────────────── */
  let showcaseIdx = 0;

  const showcaseBack = document.getElementById('showcase-back-btn');
  const prevBtn      = document.getElementById('prev-btn');
  const nextBtn      = document.getElementById('next-btn');
  const screenEl     = document.getElementById('sc-screen');
  const asetEl       = document.getElementById('sc-aset');
  const variantEl    = document.getElementById('sc-variant');
  const animEl       = document.getElementById('sc-anim');
  const namaEl       = document.getElementById('sc-nama');
  const btnEls       = Array.from(document.querySelectorAll('.sc-btn'));

  let curVariants = [];
  let curAnimations = [];

  function openShowcase(idx) {
    showcaseIdx = idx;
    renderShowcase();
    pickerView.classList.add('hidden');
    showcaseView.classList.remove('hidden');
  }

  function renderShowcase() {
    const p = projects[showcaseIdx];
    if (!p) return;

    if (screenEl) { screenEl.src = p.screen; screenEl.alt = p.name; }

    /* uiux: bobbing hero device */
    if (asetEl) {
      if (p.asset) {
        asetEl.src = p.asset;
        asetEl.style.display = '';
        asetEl.style.setProperty('--ax', p.asetX + '%');
        asetEl.style.setProperty('--ay', p.asetY + '%');
        asetEl.style.setProperty('--aw', p.asetW + '%');
      } else {
        asetEl.style.display = 'none';
        asetEl.removeAttribute('src');
      }
    }

    /* character: overlaid title */
    if (namaEl) {
      if (p.nama) { namaEl.src = p.nama; namaEl.style.display = ''; }
      else { namaEl.style.display = 'none'; namaEl.removeAttribute('src'); }
    }

    /* character: switchable portrait variants + numbered buttons + webm animation */
    curVariants = p.variants || [];
    curAnimations = p.animations || [];
    const hasVariants = curVariants.length > 0;
    const hasAnim = curAnimations.length > 0;
    if (variantEl) variantEl.style.display = hasVariants ? '' : 'none';
    if (animEl)    animEl.style.display    = hasAnim ? '' : 'none';
    btnEls.forEach((b, k) => { b.style.display = k < curVariants.length ? '' : 'none'; });
    if (hasVariants || hasAnim) selectVariant(0);   /* no-variant projects (Kidjo/Prima) still get their animation */
    else if (animEl) animEl.removeAttribute('src');

    /* Leftmost has no left arrow, rightmost has no right arrow. */
    if (prevBtn) prevBtn.classList.toggle('hidden-arrow', showcaseIdx === 0);
    if (nextBtn) nextBtn.classList.toggle('hidden-arrow', showcaseIdx === projects.length - 1);
  }

  /* Switch the displayed portrait + animation; pressed button turns into its star. */
  function selectVariant(k) {
    if (k < 0) return;
    if (variantEl && k < curVariants.length) variantEl.src = curVariants[k];
    if (animEl && curAnimations[k]) {
      if (animEl.getAttribute('src') !== curAnimations[k]) {
        animEl.src = curAnimations[k];
        animEl.load();
      }
      const playP = animEl.play();
      if (playP && playP.catch) playP.catch(() => {});
    }
    btnEls.forEach((b, i) => b.classList.toggle('selected', i === k));
  }

  btnEls.forEach((b, k) => b.addEventListener('click', () => selectVariant(k)));

  function closeShowcase() {
    showcaseView.classList.add('hidden');
    pickerView.classList.remove('hidden');
    current = showcaseIdx;
    updateCarousel();
  }

  if (showcaseBack) showcaseBack.addEventListener('click', closeShowcase);

  if (prevBtn) prevBtn.addEventListener('click', () => {
    if (showcaseIdx > 0) { showcaseIdx--; renderShowcase(); }
  });
  if (nextBtn) nextBtn.addEventListener('click', () => {
    if (showcaseIdx < projects.length - 1) { showcaseIdx++; renderShowcase(); }
  });

  /* Keyboard in showcase */
  document.addEventListener('keydown', (e) => {
    if (!showcaseView || showcaseView.classList.contains('hidden')) return;
    if (e.key === 'ArrowRight') { if (showcaseIdx < projects.length - 1) { showcaseIdx++; renderShowcase(); } }
    else if (e.key === 'ArrowLeft') { if (showcaseIdx > 0) { showcaseIdx--; renderShowcase(); } }
    else if (e.key === 'Escape') { closeShowcase(); }
  });

  /* ──────────────────────────────
     MOTION TIMELINE
  ────────────────────────────── */
  const motionTrack = document.getElementById('motion-track');
  if (motionTrack) {
    /* Vertical wheel scrolls the timeline horizontally. */
    motionTrack.addEventListener('wheel', (e) => {
      if (Math.abs(e.deltaY) <= Math.abs(e.deltaX)) return;
      e.preventDefault();
      motionTrack.scrollLeft += e.deltaY;
    }, { passive: false });

    /* Click a pill to expand/collapse it (tutup ↔ buka). */
    motionTrack.querySelectorAll('.motion-project').forEach((el) => {
      el.addEventListener('click', () => {
        const wasOpen = el.classList.contains('open');
        motionTrack.querySelectorAll('.motion-project.open').forEach((o) => o.classList.remove('open'));
        if (!wasOpen) {
          el.classList.add('open');
          el.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        }
      });
    });

    const motionBack = document.getElementById('motion-back-btn');
    if (motionBack) motionBack.addEventListener('click', () => window.history.back());

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') window.history.back();
    });
  }

  /* ──────────────────────────────
     MERCH TIMELINE (hang + jiggle)
  ────────────────────────────── */
  const merchTrack = document.getElementById('merch-track');
  if (merchTrack) {
    const items = Array.from(merchTrack.querySelectorAll('.merch-item'));

    /* Vertical wheel scrolls horizontally. */
    merchTrack.addEventListener('wheel', (e) => {
      if (Math.abs(e.deltaY) <= Math.abs(e.deltaX)) return;
      e.preventDefault();
      merchTrack.scrollLeft += e.deltaY;
    }, { passive: false });

    /* Pendulum jiggle: items lean with scroll velocity, then ease back. */
    const MAX = 13, K = 0.45, EASE = 0.12;
    let last = merchTrack.scrollLeft, angle = 0;
    function tick() {
      const sl = merchTrack.scrollLeft;
      const v = sl - last; last = sl;
      const target = Math.max(-MAX, Math.min(MAX, v * K));
      angle += (target - angle) * EASE;
      if (Math.abs(angle) < 0.01) angle = 0;
      const t = 'rotate(' + angle.toFixed(2) + 'deg)';
      for (const it of items) it.style.transform = t;
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);

    const merchBack = document.getElementById('merch-back-btn');
    if (merchBack) merchBack.addEventListener('click', () => window.history.back());
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') window.history.back(); });
  }

  /* ──────────────────────────────
     ILLUSTRATION (pan + lightbox)
  ────────────────────────────── */
  const illusWorld = document.getElementById('illus-world');
  if (illusWorld) {
    /* Pan up to the world's overhang so edges just reach, never past it.
       world is 112vw×130vh → overhang 6vw / 15vh each side. */
    const RANGE_X = 6, RANGE_Y = 15;
    document.addEventListener('mousemove', (e) => {
      const nx = (e.clientX / window.innerWidth - 0.5) * 2;   // -1..1
      const ny = (e.clientY / window.innerHeight - 0.5) * 2;
      const px = (-nx * RANGE_X).toFixed(2);  // mouse right → reveal right edge
      const py = (-ny * RANGE_Y).toFixed(2);
      illusWorld.style.transform =
        `translate(-50%, -50%) translate(${px}vw, ${py}vh)`;
    });

    /* Click a tile → full illustration in the lightbox. */
    const lightbox = document.getElementById('illus-lightbox');
    const lbImg = document.getElementById('lb-img');
    const lbClose = document.getElementById('lb-close');
    illusWorld.querySelectorAll('.illus-tile').forEach((tile) => {
      tile.addEventListener('click', () => {
        lbImg.src = tile.getAttribute('data-full');
        lightbox.classList.remove('hidden');
      });
    });
    function closeLightbox() { lightbox.classList.add('hidden'); lbImg.removeAttribute('src'); }
    if (lbClose) lbClose.addEventListener('click', closeLightbox);
    if (lightbox) lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });

    const illusBack = document.getElementById('illus-back-btn');
    if (illusBack) illusBack.addEventListener('click', () => window.history.back());
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        if (lightbox && !lightbox.classList.contains('hidden')) closeLightbox();
        else window.history.back();
      }
    });
  }

  /* Init */
  if (projects.length > 0) buildTrack();
})();
</script>
</body>
</html>
