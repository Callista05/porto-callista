<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{data.label} — Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Nova+Flat&family=Barlow+Condensed:ital,wght@0,400;0,700;1,700&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html, body { height:100%; overflow:hidden; }
    body { background:#000; font-family:'Nova Flat', cursive; color:#eeebeb; }

    /* ═══════════ SHARED ═══════════ */
    .view {
      position:fixed; inset:0;
      transition: opacity 0.5s ease;
    }
    .view.hidden { opacity:0; pointer-events:none; }

    /* ═══════════ PICKER VIEW ═══════════ */
    #picker-view { background:#050208; }

    /* Left decorative area — purple swirl (Lingkaran.svg) */
    .picker-left {
      position:absolute; left:0; top:0;
      width:55%; height:100%;
      overflow:hidden; pointer-events:none;
    }
    .swirl-img {
      position:absolute;
      left:-14%; top:50%;
      transform:translateY(-50%);
      width:90%; height:auto;
      max-height:130%;
      object-fit:contain;
    }

    /* Faint gold constellation lines on the right (Garis kuning.svg) */
    .gold-lines {
      position:absolute; right:0; top:0;
      height:100%; width:auto;
      pointer-events:none;
      opacity:.8;
      z-index:0;
    }

    /* Panel header: category label + close */
    .picker-header {
      position:absolute; top:1.6rem; right:5%;
      display:flex; align-items:center; gap:1rem;
      opacity:.7; z-index:5;
    }
    .cat-chip {
      font-family:'Barlow Condensed',sans-serif;
      font-size:.65rem; letter-spacing:.18em; text-transform:uppercase;
      color:#eeebeb;
    }
    .picker-close {
      background:none; border:none; cursor:pointer;
      color:#eeebeb; font-size:1rem; opacity:.7;
      transition:opacity .2s; padding:.2rem .4rem;
    }
    .picker-close:hover { opacity:1; }

    /* Carousel fills the screen; the active item is anchored near center. */
    .carousel-window {
      position:fixed; inset:0;
      pointer-events:none;
    }
    .carousel-track {
      position:absolute;
      top:50%;
      left:34%;        /* active item (star) sits around screen center */
      width:0; height:0;
    }

    /* Each item is placed by JS: rotated about a hub off to the LEFT (the
       swirl's center), so rows arc around the circle and the wheel appears
       to spin as you select. The active item is upright + screen-centered.
       height:0 + align-items:center keeps every row's vertical CENTER pinned
       to the track origin, so the active item never drifts as you scroll. */
    .c-item {
      position:absolute; left:0; top:0; height:0;
      display:flex; align-items:center; gap:1.3rem;
      white-space:nowrap;
      cursor:pointer;
      transition: transform .6s cubic-bezier(.33,1,.68,1),
                  opacity   .5s ease;
    }

    /* Star (white when active / gold otherwise) */
    .c-star {
      position:relative; flex-shrink:0;
      width:1.8rem; height:1.8rem;
      transition:width .4s, height .4s;
    }
    .c-star img {
      position:absolute; inset:0;
      width:100%; height:100%;
      transition:opacity .4s;
    }
    .c-star .star-on  { opacity:0; }   /* white, shown when active */
    .c-star .star-off { opacity:1; }   /* gold */

    .c-num {
      font-family:'Barlow Condensed',sans-serif;
      font-weight:700; font-style:italic;
      flex-shrink:0; text-align:left;
      font-size:3.2rem; line-height:.85;
      color:transparent;
      -webkit-text-stroke:1.6px #ce9566;
      transition:font-size .4s, color .4s;
    }
    .c-info {
      display:none; flex-direction:column;
    }
    .c-name {
      font-family:'Barlow Condensed',sans-serif;
      font-weight:700; text-transform:uppercase; letter-spacing:.06em;
      color:#eeebeb; line-height:1;
    }
    .c-year {
      font-family:'Barlow Condensed',sans-serif;
      opacity:.6; letter-spacing:.1em; color:#eeebeb;
      margin-top:.25rem;
    }

    /* Active item — white star, solid white number (biggest), full info.
       The number's font-size is sized to roughly match name+year height. */
    .c-item[data-active="true"] { opacity:1; }
    .c-item[data-active="true"] .c-star { width:3rem; height:3rem; }
    .c-item[data-active="true"] .c-star .star-on  { opacity:1; }
    .c-item[data-active="true"] .c-star .star-off { opacity:0; }
    .c-item[data-active="true"] .c-num  { font-size:5.5rem; color:#eeebeb; -webkit-text-stroke:0; }
    .c-item[data-active="true"] .c-name { font-size:2.6rem; }
    .c-item[data-active="true"] .c-year { font-size:1.2rem; }
    .c-item[data-active="true"] .c-info { display:flex; }

    /* Adjacent items — gold, outlined number only */
    .c-item[data-dist="1"] { opacity:.95; }
    .c-item[data-dist="1"] .c-star { width:1.8rem; height:1.8rem; }
    .c-item[data-dist="1"] .c-num  { font-size:3.4rem; }

    /* Far items */
    .c-item[data-dist="2"] { opacity:.45; }
    .c-item[data-dist="2"] .c-star { width:1.3rem; height:1.3rem; }
    .c-item[data-dist="2"] .c-num  { font-size:2.3rem; }

    /* Beyond range: hidden */
    .c-item[data-dist="3"],
    .c-item[data-dist="4"],
    .c-item[data-dist="5"] { opacity:0; pointer-events:none; }

    /* Picker footer tag */
    .picker-footer {
      position:absolute; bottom:1.8rem; left:50%;
      transform:translateX(-50%);
      font-family:'Barlow Condensed',sans-serif;
      font-size:.7rem; letter-spacing:.22em;
      text-transform:uppercase; opacity:.5;
    }

    /* Scroll hint arrows */
    .scroll-hints {
      position:absolute; right:5%; top:50%;
      transform:translateY(-50%);
      display:flex; flex-direction:column; gap:1rem; opacity:.3;
      font-size:.75rem;
    }

    /* ═══════════ SHOWCASE VIEW ═══════════ */
    #showcase-view { background:#050208; }

    /* Full-bleed background swirl */
    .sc-bg {
      position:absolute; inset:0;
      width:100%; height:100%;
      object-fit:cover;
      pointer-events:none;
    }

    /* The Screen image drives the stage size: it fills the viewport width and
       its natural aspect sets the height (each Screen SVG has a slightly
       different aspect). The stage hugs the image so the Aset can be anchored
       as a % of the Screen. Vertical overflow is clipped by body overflow. */
    .sc-stage {
      position:absolute; top:60%; left:40%;
      transform:translate(-50%, -50%);
      width:110vw;
    }
    .sc-screen {
      display:block;
      width:100%; height:auto;
    }
    /* Hero device — bobs slowly above the title. Position is per-project,
       fed in via --ax/--ay (center %) and --aw (width % of stage). */
    .sc-aset {
      position:absolute;
      left:var(--ax, 30%); top:var(--ay, 31%);
      width:var(--aw, 38%); height:auto;
      animation:bob 4.5s ease-in-out infinite;
      filter:drop-shadow(0 18px 30px rgba(0,0,0,.45));
    }
    @keyframes bob {
      0%,100% { transform:translate(-50%, -50%); }
      50%     { transform:translate(-50%, calc(-50% - 12px)); }
    }

    /* ─── Character mode overlays (title + switchable portrait + buttons) ─── */
    .sc-variant {            /* switchable portrait, left */
      position:absolute;
      left:35%; top:30%;
      width:24%; height:auto;
      transform:translate(-50%, -50%);
    }
    .sc-nama {               /* title image, top-right above the description */
      position:absolute;
      left:80%; top:27%;
      width:32%; height:auto;
      transform:translate(-50%, -50%);
    }
    .sc-anim {               /* per-variant webm animation, middle (portrait) */
      position:absolute;
      left:50%; top:52%;
      height:54%; width:auto;
      transform:translate(-50%, -50%);
      object-fit:contain;
    }
    .sc-buttons {            /* variant buttons, under the portrait */
      position:absolute;
      left:33%; top:60%;
      transform:translateX(-50%);
      width:20%;
      display:flex; flex-wrap:wrap; gap:.55rem;
      justify-content:center;
    }
    .sc-btn {
      position:relative;
      width:2.4rem; height:2.4rem;
      background:none; border:none; padding:0; cursor:pointer;
      transition:transform .15s ease;
    }
    .sc-btn img { position:absolute; inset:0; width:100%; height:100%; }
    .sc-btn .btn-star { opacity:0; }
    .sc-btn.selected .btn-num  { opacity:0; }
    .sc-btn.selected .btn-star { opacity:1; }
    .sc-btn:hover { transform:scale(1.1); }

    /* Back button (top center) */
    .showcase-back {
      position:absolute; top:1.4rem; left:50%;
      transform:translateX(-50%);
      background:none; border:none; cursor:pointer;
      opacity:.8; transition:opacity .2s; z-index:5;
    }
    .showcase-back img { height:.85rem; width:auto; display:block; }
    .showcase-back:hover { opacity:1; }

    /* Left / Right nav arrows */
    .nav-arrow {
      position:absolute; top:50%;
      transform:translateY(-50%);
      background:none; border:none; cursor:pointer;
      opacity:.7; transition:opacity .2s; z-index:5;
      padding:.8rem;
    }
    .nav-arrow img { width:1.6rem; height:auto; display:block; }
    .nav-arrow:hover { opacity:1; }
    .nav-arrow.left  { left:1.8rem; }
    .nav-arrow.right { right:1.8rem; }
    .nav-arrow.hidden-arrow { display:none; }

    /* ═══════════ MOTION VIEW (horizontal timeline) ═══════════ */
    #motion-view { background:#050208; }
    .motion-bg {
      position:absolute; inset:0;
      width:100%; height:100%; object-fit:cover;
      pointer-events:none;
    }
    .motion-back {
      position:absolute; top:1.4rem; left:50%;
      transform:translateX(-50%);
      background:none; border:none; cursor:pointer;
      opacity:.8; transition:opacity .2s; z-index:5;
    }
    .motion-back img { height:.85rem; width:auto; display:block; }
    .motion-back:hover { opacity:1; }

    .motion-track {
      position:absolute; inset:0;
      display:flex; align-items:center; gap:4vw;
      padding:0 12vw;
      overflow-x:auto; overflow-y:hidden;
      scroll-behavior:smooth;
      -ms-overflow-style:none; scrollbar-width:none;
    }
    .motion-track::-webkit-scrollbar { display:none; }

    .motion-circle {
      flex:0 0 auto;
      height:36vh; width:auto;
      user-select:none; -webkit-user-drag:none;
    }
    .motion-project {
      flex:0 0 auto;
      background:none; border:none; padding:0; cursor:pointer;
      height:72vh;
      display:flex; align-items:center;
    }
    .motion-project img { height:100%; width:auto; display:block; -webkit-user-drag:none; }
    .motion-project .mp-buka  { display:none; }
    .motion-project.open .mp-tutup { display:none; }
    .motion-project.open .mp-buka  { display:block; }

    /* ═══════════ MERCH VIEW (hanging keychains/pins/stickers) ═══════════ */
    #merch-view {
      background:
        radial-gradient(ellipse 70% 60% at 50% 118%, #2a1060 0%, transparent 60%),
        #08040f;
    }
    .merch-back {
      position:absolute; top:1.4rem; left:50%;
      transform:translateX(-50%);
      background:none; border:none; cursor:pointer;
      opacity:.8; transition:opacity .2s; z-index:6;
    }
    .merch-back img { height:.85rem; width:auto; display:block; }
    .merch-back:hover { opacity:1; }
    .merch-title {
      position:absolute; top:3rem; left:50%;
      transform:translateX(-50%);
      height:4.6rem; width:auto; z-index:6;
      pointer-events:none;
    }

    .merch-track {
      position:absolute; inset:0;
      overflow-x:auto; overflow-y:hidden;
      -ms-overflow-style:none; scrollbar-width:none;
    }
    .merch-track::-webkit-scrollbar { display:none; }
    .merch-strip {
      position:relative; height:100%; width:max-content;
      display:flex; align-items:flex-start; gap:4vw;
      padding:18vh 9vw 0;
    }
    .merch-rod {              /* endless horizontal bar — overhangs both ends */
      position:absolute; top:24vh; left:-100vw;
      width:calc(100% + 100vw); height:3px;
      background:#6a4bd0;
      box-shadow:0 0 9px rgba(138,106,224,.7);
      z-index:0;
    }

    .merch-item {
      position:relative; z-index:1; flex:0 0 auto;
      height:62vh;
      transform-origin:top center;   /* swings like a pendulum on scroll */
    }
    .merch-item > .ungu,            /* keychain art */
    .merch-item > .real,
    .merch-item > .strap-bg,
    .merch-item > .paper-bg {
      display:block; height:100%; width:auto;
    }
    /* hover reveals the real artwork for the whole hanging unit */
    .ungu, .real { transition:opacity .3s ease; }
    .merch-item > .real { position:absolute; top:0; left:0; opacity:0; }
    .merch-item:hover > .real { opacity:1; }
    .merch-item:hover > .ungu { opacity:0; }

    /* pins on a strap / stickers on paper — nested, positioned % of backing */
    .pin, .sticker {
      position:absolute; left:50%; transform:translateX(-50%);
    }
    .pin { width:74%; } .sticker { width:62%; }
    .pin img, .sticker img { display:block; width:100%; height:auto; }
    .pin .real, .sticker .real { position:absolute; top:0; left:0; opacity:0; }
    .merch-item:hover .pin .real,
    .merch-item:hover .sticker .real { opacity:1; }
    .merch-item:hover .pin .ungu,
    .merch-item:hover .sticker .ungu { opacity:0; }
    .pin[data-pos="0"]     { top:30%; }
    .pin[data-pos="1"]     { top:65%; }
    .sticker[data-pos="0"] { top:25%; }
    .sticker[data-pos="1"] { top:45%; left:70% }

    .merch-fade {
      position:absolute; top:0; height:100%; width:auto;
      pointer-events:none; z-index:4;
    }
    .merch-fade.left  { left:0; }
    .merch-fade.right { right:0; }

    /* ═══════════ ILLUSTRATION VIEW (pannable collage) ═══════════ */
    #illus-view { background:#050208; overflow:hidden; }
    .illus-back {
      position:absolute; top:1.4rem; left:50%;
      transform:translateX(-50%);
      background:none; border:none; cursor:pointer;
      opacity:.8; transition:opacity .2s; z-index:8;
    }
    .illus-back img { height:.85rem; width:auto; display:block; }
    .illus-back:hover { opacity:1; }

    .illus-world {
      position:absolute; top:50%; left:50%;
      width:112vw; height:130vh;
      transform:translate(-50%, -50%);
      transition:transform .35s ease-out;   /* smooth camera pan */
    }
    .illus-marker, .illus-tile {
      position:absolute;
      transform:translate(-50%, -50%);
      width:24vmin;
    }
    .illus-marker.wide, .illus-tile.wide { width:46vmin; }
    .illus-marker { pointer-events:none; }
    .illus-marker img { display:block; width:100%; height:auto; }

    .illus-tile {
      background:none; border:none; padding:0; cursor:pointer;
    }
    .illus-tile img { display:block; width:100%; height:auto; }
    .illus-tile .ilus-clear {
      position:absolute; top:0; left:0;
      opacity:0; transition:opacity .3s ease;
    }
    .illus-tile:hover { z-index:6; }
    .illus-tile:hover .ilus-clear { opacity:1; }

    /* Lightbox — full illustration over a dimmed grid */
    .illus-lightbox {
      position:fixed; inset:0; z-index:20;
      display:flex; align-items:center; justify-content:center;
      background:rgba(5,2,8,.82);
      opacity:1; transition:opacity .3s ease;
    }
    .illus-lightbox.hidden { opacity:0; pointer-events:none; }
    .illus-lightbox img {
      max-width:86vw; max-height:84vh;
      width:auto; height:auto;
      border-radius:.4rem;
    }
    .lb-close {
      position:absolute; top:1.4rem; right:2rem;
      background:none; border:none; cursor:pointer;
      color:#eeebeb; font-size:1.4rem; opacity:.8; transition:opacity .2s;
    }
    .lb-close:hover { opacity:1; }

    /* Empty state */
    .empty-state {
      position:absolute; inset:0;
      display:flex; flex-direction:column;
      align-items:center; justify-content:center; gap:1.5rem;
      text-align:center;
    }
    .empty-star {
      font-size:3rem; color:#3a1789;
      filter:drop-shadow(0 0 20px rgba(100,40,200,.5));
    }
    .empty-title {
      font-family:'Barlow Condensed',sans-serif;
      font-size:1.2rem; letter-spacing:.3em;
      text-transform:uppercase; opacity:.5;
    }
    .empty-back {
      margin-top:.5rem;
      background:none; border:1px solid rgba(200,200,200,.2);
      color:#eeebeb; padding:.6rem 1.8rem;
      font-family:'Barlow Condensed',sans-serif;
      font-size:.75rem; letter-spacing:.25em; text-transform:uppercase;
      cursor:pointer; opacity:.65; transition:opacity .2s;
    }
    .empty-back:hover { opacity:1; }
  </style>
</head>
<body>

{isCollage ? (
